apiVersion: v1
kind: PersistentVolume
metadata:
  name: homelab-s3-pv
spec:
  capacity:
    storage: 1200Gi   # Required by K8s, ignored by S3 CSI
  accessModes:
    - ReadWriteMany   # or ReadOnlyMany
  storageClassName: ""  # Required for static provisioning
  claimRef:             # Reserves this PV for one PVC
    namespace: default
    name: homelab-s3-pvc
  mountOptions:
    - region us-east-1
    # - prefix some/path/          # optional: mount a prefix
    # - allow-delete               # optional: allow deletes via filesystem
  csi:
    driver: s3.csi.aws.com
    volumeHandle: homelab-s3-pv   # Must be unique cluster-wide
    volumeAttributes:
      bucketName: my-homelab-bucket
      authenticationSource: driver  # default; uses s3-csi-driver-sa
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: homelab-s3-pvc
  namespace: default
spec:
  accessModes:
    - ReadWriteMany
  storageClassName: ""
  resources:
    requests:
      storage: 1200Gi
  volumeName: homelab-s3-pv
---
apiVersion: v1
kind: Pod
metadata:
  name: s3-app
  namespace: default
spec:
  containers:
    - name: app
      image: ubuntu:22.04
      command: ["/bin/sh", "-c"]
      args:
        - echo "Hello from $(date -u)" >> /data/test.txt; tail -f /dev/null
      volumeMounts:
        - name: s3-storage
          mountPath: /data
  volumes:
    - name: s3-storage
      persistentVolumeClaim:
        claimName: homelab-s3-pvc