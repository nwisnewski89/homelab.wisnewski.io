frontend fe_main
  bind *:8080   # whatever Ingress sends you (usually HTTP)
  # Preserve the real client chain from NLB/ALB/Ingress — do NOT overwrite with option forwardfor
  http-request set-header X-Real-IP %[req.hdr(X-Forwarded-For,1)] if { req.hdr(X-Forwarded-For) -m found }
  # Tell Keycloak/F5 the original public URL (no :443 in host)
  http-request set-header X-Forwarded-Proto https
  http-request set-header X-Forwarded-Port 443
  http-request set-header X-Forwarded-Host %[req.hdr(host),field(1,:)]
  # Strip :443 from Host before sending upstream (common root cause of fqdn:443 redirects)
  http-request set-header Host %[req.hdr(host),field(1,:)]
  default_backend backend

backend backend
  server backend1 x.x.x.x:443 ssl verify required ca-file /etc/ssl/certs/ca-certificates.crt check
  # Safety net: rewrite any 302/301 Location that still includes :443
  http-response replace-header Location ^(https?://[^/:]+):443(.*)$ \1\2