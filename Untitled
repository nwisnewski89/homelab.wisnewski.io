<firewall_aliases>
  <alias name="Allowed_Sites" type="host">
    <content>
      ifconfig.me
      wtfismyip.com
      google.com
    </content>
    <description>Allowed urls</description>
  </alias>
</firewall_aliases>

<firewall_rules>
  <wan>
    <rule action="pass" direction="in" protocol="tcp">
      <source>68.194.23.90/32</source>
      <destination>(self)</destination>
      <port>22</port>
      <description>Allow SSH on WAN</description>
    </rule>

    <rule action="pass" direction="in" protocol="tcp">
      <source>68.194.23.90/32</source>
      <destination>(self)</destination>
      <port>443</port>
      <description>Allow HTTPS on WAN</description>
    </rule>
  </wan>

  <lan disabled="true">
    <rule action="pass">
      <source>lan net</source>
      <destination>any</destination>
      <description>Default allow LAN to any rule</description>
    </rule>

    <rule action="pass" ipprotocol="inet6" disabled="true">
      <source>lan net</source>
      <destination>any</destination>
      <description>Default allow LAN IPv6 to any rule</description>
    </rule>

    <rule action="pass" direction="in" protocol="udp">
      <source>lan net</source>
      <destination>any</destination>
      <port>53</port>
      <description>allow DNS</description>
    </rule>

    <rule action="pass" direction="in" protocol="tcp">
      <source>lan net</source>
      <destination>Allowed_Sites</destination>
      <port>443</port>
      <description>allow HTTPS to allowed sites only</description>
    </rule>

    <rule action="block" direction="in">
      <source>lan net</source>
      <destination>any</destination>
      <description>block everything else</description>
    </rule>
  </lan>

  <opt1 description="LAN">
    <rule action="pass" direction="in" protocol="udp">
      <source>opt1 net</source>
      <destination>any</destination>
      <port>53</port>
      <description>DNS Output</description>
    </rule>

    <rule action="pass" direction="in" protocol="tcp">
      <source>opt1 net</source>
      <destination>Allowed_Sites</destination>
      <port>443</port>
    </rule>

    <rule action="pass" direction="in" protocol="tcp">
      <source>opt1 net</source>
      <destination>Allowed_Sites</destination>
      <port>80</port>
    </rule>

    <rule action="block" direction="in">
      <source>any</source>
      <destination>any</destination>
    </rule>
  </opt1>
</firewall_rules>

<nat>
  <outbound mode="hybrid">
    <rule>
      <interface>wan</interface>
      <ipprotocol>inet</ipprotocol>
      <source>10.10.1.0/24</source>
      <destination>any</destination>
      <translation>wan address</translation>
    </rule>
  </outbound>
</nat>