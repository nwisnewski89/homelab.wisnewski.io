[build-system]
requires = ["setuptools>=69", "setuptools-scm>=8", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "proj-a"
dynamic = ["version"]

[tool.setuptools_scm]
# only tags matching this project are used
tag_regex = "^proj-a-v(?P<version>\\d+\\.\\d+\\.\\d+)$"
version_scheme = "release-branch-semver"
local_scheme = "no-local-version"


def projPath = "packages/proj-a"
def distName = "PROJ_A" // normalized distribution name: upper + non-alnum -> _

sh """
  set -euo pipefail
  if [ -f "${projPath}/VERSION" ]; then
    V=\$(tr -d '[:space:]' < "${projPath}/VERSION")
    export SETUPTOOLS_SCM_PRETEND_VERSION_FOR_${distName}="\$V"
    echo "Using VERSION file override: \$V"
  else
    echo "No VERSION file, using git tag regex"
  fi

  python -m pip install --upgrade pip build
  python -m build --wheel "${projPath}"
"""